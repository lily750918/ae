# 复制此文件为 .env 并填写真实值，然后 chmod 600 .env
# 生成强密码: python3 -c "import secrets; print(secrets.token_urlsafe(24))"

# ========== 必填 ==========
AE_ADMIN_PASSWORD=        # Web 界面登录密码，长度 >= 16 位
AE_ADMIN_USER=admin       # Web 界面用户名（可不改）

# ========== Binance API（也可写入 config.ini）==========
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ========== 邮件报警（可选）==========
AE_ALERT_EMAIL=           # 报警接收邮箱
SMTP_EMAIL=               # 发件邮箱（163/QQ 等）
SMTP_PASSWORD=            # 邮箱授权码（非登录密码）

# ========== 网络配置（可选）==========
# AE_HOST=127.0.0.1        # 监听地址，改为 0.0.0.0 可公网访问（建议配 Nginx 反代+TLS）
# AE_ALLOWED_ORIGINS=      # 允许跨域的前端地址，逗号分隔，例: https://example.com
# AE_TRUSTED_PROXIES=      # 可信反向代理 IP，逗号分隔，例: 127.0.0.1
